# Copy to `.env` and fill in values. Never commit `.env`.

# Required for LLM calls (OpenRouter — OpenAI-compatible API)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional OpenRouter attribution (recommended for rankings)
OPENROUTER_HTTP_REFERER=https://github.com/kirtquist/service-app
OPENROUTER_X_TITLE=Service App MVP

# Default model on OpenRouter (change to any router-supported ID)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Future: Postgres or SQLite URL for app data (jobs, customers — not API keys by default)
# DATABASE_URL=sqlite:///./data/service_app.db

# --- WhatsApp Phase 1a (see docs/WHATSAPP_SETUP.md) ---

# Meta Cloud API
# WHATSAPP_VERIFY_TOKEN=your-chosen-verify-string
# WHATSAPP_ACCESS_TOKEN=...
# WHATSAPP_PHONE_NUMBER_ID=...

# Twilio sandbox (set TWILIO_VALIDATE_SIGNATURES=false for local dev without ngrok)
# TWILIO_AUTH_TOKEN=...
# TWILIO_VALIDATE_SIGNATURES=true
# PUBLIC_BASE_URL=https://your-cloud-run-url.run.app
