# Copy to `.env` and fill in values. Never commit `.env`.

# Required for LLM calls (OpenRouter — OpenAI-compatible API)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional OpenRouter attribution (recommended for rankings)
OPENROUTER_HTTP_REFERER=https://github.com/kirtquist/service-app
OPENROUTER_X_TITLE=Service App MVP

# Default model on OpenRouter (change to any router-supported ID)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Future: Postgres or SQLite URL for app data (jobs, customers — not API keys by default)
# DATABASE_URL=sqlite:///./data/service_app.db
